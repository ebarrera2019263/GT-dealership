# Base de datos (docker-compose local)
DATABASE_URL="postgresql://concesionario:concesionario@localhost:5433/concesionario?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT — generar un secreto real con: openssl rand -base64 48
JWT_ACCESS_SECRET="cambiame-por-un-secreto-largo"
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DIAS=30

# Servidor
PORT=3001
CORS_ORIGIN="http://localhost:3000"
