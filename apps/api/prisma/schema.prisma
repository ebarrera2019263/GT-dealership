// Schema del marketplace de vehículos usados.
// Fuente de diseño: esquema-marketplace-vehiculos.md §3.
// Convención: modelos en PascalCase español, tablas/columnas en snake_case vía @map.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Rol {
  comprador
  vendedor
  concesionario
  admin
}

enum Moneda {
  GTQ
  USD
}

enum Traccion {
  T4X2 @map("4x2")
  T4X4 @map("4x4")
  AWD
}

// Máquina de estados del anuncio (esquema §4)
enum EstadoVehiculo {
  borrador
  en_revision
  publicado
  rechazado
  pausado
  expirado
  vendido
}

enum CanalLead {
  formulario
  whatsapp
  llamada
}

enum EstadoCita {
  pendiente
  confirmada
  cancelada
}

enum EstadoReporte {
  abierto
  resuelto
}

enum EstadoSolicitudCredito {
  enviada
  en_revision
  aprobada
  rechazada
}

enum AplicaA {
  todos
  verificados
  concesionario
}

enum EstadoSuscripcion {
  activa
  vencida
  cancelada
}

enum ConceptoPago {
  suscripcion
  destacado
}

enum EstadoPago {
  pendiente
  completado
  fallido
  reembolsado
}

// ────────────────────── Catálogo maestro ─────────────────────
// Lo llena el admin, no los usuarios: sin esto normalizado los filtros no funcionan.

model Marca {
  id      Int     @id @default(autoincrement())
  nombre  String  @unique
  slug    String  @unique
  logoUrl String? @map("logo_url")
  activo  Boolean @default(true)

  modelos   Modelo[]
  vehiculos Vehiculo[]

  @@map("marcas")
}

model Modelo {
  id      Int     @id @default(autoincrement())
  marcaId Int     @map("marca_id")
  nombre  String
  slug    String
  activo  Boolean @default(true)

  marca     Marca      @relation(fields: [marcaId], references: [id])
  vehiculos Vehiculo[]

  @@unique([marcaId, slug])
  @@map("modelos")
}

model Carroceria {
  id     Int     @id @default(autoincrement())
  nombre String  @unique
  slug   String  @unique
  icono  String?

  vehiculos Vehiculo[]

  @@map("carrocerias")
}

model Combustible {
  id     Int    @id @default(autoincrement())
  nombre String @unique

  vehiculos Vehiculo[]

  @@map("combustibles")
}

model Transmision {
  id     Int    @id @default(autoincrement())
  nombre String @unique

  vehiculos Vehiculo[]

  @@map("transmisiones")
}

model Caracteristica {
  id        Int    @id @default(autoincrement())
  nombre    String @unique
  categoria String

  vehiculos VehiculoCaracteristica[]

  @@map("caracteristicas")
}

model Departamento {
  id     Int    @id @default(autoincrement())
  nombre String @unique

  municipios Municipio[]
  vehiculos  Vehiculo[]

  @@map("departamentos")
}

model Municipio {
  id             Int    @id @default(autoincrement())
  departamentoId Int    @map("departamento_id")
  nombre         String

  departamento Departamento @relation(fields: [departamentoId], references: [id])
  vehiculos    Vehiculo[]

  @@unique([departamentoId, nombre])
  @@map("municipios")
}

// ───────────────────────── Usuarios ──────────────────────────

model Usuario {
  id                 Int      @id @default(autoincrement())
  nombre             String
  email              String   @unique
  telefono           String?
  passwordHash       String   @map("password_hash")
  rol                Rol      @default(comprador)
  emailVerificado    Boolean  @default(false) @map("email_verificado")
  telefonoVerificado Boolean  @default(false) @map("telefono_verificado")
  avatarUrl          String?  @map("avatar_url")
  activo             Boolean  @default(true)
  creadoEn           DateTime @default(now()) @map("creado_en")
  actualizadoEn      DateTime @updatedAt @map("actualizado_en")

  concesionario           Concesionario?
  vehiculos               Vehiculo[]
  favoritos               Favorito[]
  conversacionesComprador Conversacion[]      @relation("ConversacionComprador")
  conversacionesVendedor  Conversacion[]      @relation("ConversacionVendedor")
  mensajes                Mensaje[]
  busquedasGuardadas      BusquedaGuardada[]
  citas                   Cita[]
  reportes                Reporte[]
  solicitudesCredito      SolicitudCredito[]
  suscripciones           Suscripcion[]
  pagos                   Pago[]
  auditoria               Auditoria[]
  refreshTokens           RefreshToken[]

  @@map("usuarios")
}

// Perfil extendido, solo para rol concesionario
model Concesionario {
  id              Int      @id @default(autoincrement())
  usuarioId       Int      @unique @map("usuario_id")
  nombreComercial String   @map("nombre_comercial")
  nit             String?
  direccion       String?
  logoUrl         String?  @map("logo_url")
  planId          Int?     @map("plan_id")
  verificado      Boolean  @default(false)
  creadoEn        DateTime @default(now()) @map("creado_en")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  plan    Plan?   @relation(fields: [planId], references: [id])

  @@map("concesionarios")
}

// Sesiones revocables: se guarda el hash del refresh token, nunca el token.
model RefreshToken {
  id        String    @id @default(uuid())
  usuarioId Int       @map("usuario_id")
  tokenHash String    @unique @map("token_hash")
  expiraEn  DateTime  @map("expira_en")
  revocadoEn DateTime? @map("revocado_en")
  creadoEn  DateTime  @default(now()) @map("creado_en")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("refresh_tokens")
}

// ──────────────────── Vehículos (tabla central) ───────────────────

model Vehiculo {
  id     Int    @id @default(autoincrement())
  uuid   String @unique @default(uuid())
  slug   String @unique

  usuarioId Int @map("usuario_id")

  marcaId      Int @map("marca_id")
  modeloId     Int @map("modelo_id")
  carroceriaId Int @map("carroceria_id")

  anio    Int
  version String?

  precio           Decimal @db.Decimal(12, 2)
  moneda           Moneda  @default(GTQ)
  // Normalizado con el tipo de cambio vigente al escribir: los filtros y el
  // ordenamiento por precio operan siempre sobre esta columna.
  precioGtq        Decimal @map("precio_gtq") @db.Decimal(12, 2)
  precioNegociable Boolean @default(false) @map("precio_negociable")

  kilometraje Int

  transmisionId Int @map("transmision_id")
  combustibleId Int @map("combustible_id")

  cilindrada Decimal?  @db.Decimal(4, 1)
  potencia   Int?
  puertas    Int?
  color      String?
  traccion   Traccion?

  // Privados: nunca se exponen en la API pública, solo admin
  placaParcial String? @map("placa_parcial")
  vin          String?

  numDuenos   Int?    @map("num_duenos")
  descripcion String?

  departamentoId Int @map("departamento_id")
  municipioId    Int @map("municipio_id")

  estado         EstadoVehiculo @default(borrador)
  verificado     Boolean        @default(false)
  destacado      Boolean        @default(false)
  destacadoHasta DateTime?      @map("destacado_hasta")

  vistas    Int @default(0)
  contactos Int @default(0)

  publicadoEn   DateTime? @map("publicado_en")
  expiraEn      DateTime? @map("expira_en")
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")

  usuario         Usuario                  @relation(fields: [usuarioId], references: [id])
  marca           Marca                    @relation(fields: [marcaId], references: [id])
  modelo          Modelo                   @relation(fields: [modeloId], references: [id])
  carroceria      Carroceria               @relation(fields: [carroceriaId], references: [id])
  transmision     Transmision              @relation(fields: [transmisionId], references: [id])
  combustible     Combustible              @relation(fields: [combustibleId], references: [id])
  departamento    Departamento             @relation(fields: [departamentoId], references: [id])
  municipio       Municipio                @relation(fields: [municipioId], references: [id])
  imagenes        VehiculoImagen[]
  caracteristicas VehiculoCaracteristica[]
  favoritos       Favorito[]
  conversaciones  Conversacion[]
  leads           Lead[]
  citas           Cita[]
  reportes        Reporte[]
  solicitudes     SolicitudCredito[]

  // El listado público siempre filtra por estado; precio/año/km son los filtros principales.
  @@index([estado, precioGtq])
  @@index([estado, anio])
  @@index([estado, kilometraje])
  @@index([marcaId, modeloId])
  @@index([departamentoId])
  @@index([usuarioId])
  @@index([expiraEn])
  @@map("vehiculos")
}

model VehiculoImagen {
  id          Int     @id @default(autoincrement())
  vehiculoId  Int     @map("vehiculo_id")
  url         String
  urlThumb    String? @map("url_thumb")
  orden       Int     @default(0)
  esPrincipal Boolean @default(false) @map("es_principal")

  vehiculo Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@index([vehiculoId])
  @@map("vehiculo_imagenes")
}

model VehiculoCaracteristica {
  vehiculoId       Int @map("vehiculo_id")
  caracteristicaId Int @map("caracteristica_id")

  vehiculo       Vehiculo       @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  caracteristica Caracteristica @relation(fields: [caracteristicaId], references: [id])

  @@id([vehiculoId, caracteristicaId])
  @@map("vehiculo_caracteristicas")
}

// ─────────────────────── Interacción ────────────────────────

model Favorito {
  usuarioId  Int      @map("usuario_id")
  vehiculoId Int      @map("vehiculo_id")
  creadoEn   DateTime @default(now()) @map("creado_en")

  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  vehiculo Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@id([usuarioId, vehiculoId])
  @@map("favoritos")
}

model Conversacion {
  id              Int       @id @default(autoincrement())
  vehiculoId      Int       @map("vehiculo_id")
  compradorId     Int       @map("comprador_id")
  vendedorId      Int       @map("vendedor_id")
  ultimoMensajeEn DateTime? @map("ultimo_mensaje_en")

  vehiculo  Vehiculo  @relation(fields: [vehiculoId], references: [id])
  comprador Usuario   @relation("ConversacionComprador", fields: [compradorId], references: [id])
  vendedor  Usuario   @relation("ConversacionVendedor", fields: [vendedorId], references: [id])
  mensajes  Mensaje[]

  @@unique([vehiculoId, compradorId])
  @@index([vendedorId])
  @@map("conversaciones")
}

model Mensaje {
  id             Int      @id @default(autoincrement())
  conversacionId Int      @map("conversacion_id")
  emisorId       Int      @map("emisor_id")
  contenido      String
  leido          Boolean  @default(false)
  creadoEn       DateTime @default(now()) @map("creado_en")

  conversacion Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  emisor       Usuario      @relation(fields: [emisorId], references: [id])

  @@index([conversacionId, creadoEn])
  @@map("mensajes")
}

model Lead {
  id         Int       @id @default(autoincrement())
  vehiculoId Int       @map("vehiculo_id")
  nombre     String
  telefono   String?
  email      String?
  canal      CanalLead
  creadoEn   DateTime  @default(now()) @map("creado_en")

  vehiculo Vehiculo @relation(fields: [vehiculoId], references: [id])

  @@index([vehiculoId])
  @@map("leads")
}

model BusquedaGuardada {
  id                 Int       @id @default(autoincrement())
  usuarioId          Int       @map("usuario_id")
  criterios          Json
  alertaActiva       Boolean   @default(true) @map("alerta_activa")
  ultimaNotificacion DateTime? @map("ultima_notificacion")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("busquedas_guardadas")
}

model Cita {
  id          Int        @id @default(autoincrement())
  vehiculoId  Int        @map("vehiculo_id")
  compradorId Int        @map("comprador_id")
  fecha       DateTime
  estado      EstadoCita @default(pendiente)

  vehiculo  Vehiculo @relation(fields: [vehiculoId], references: [id])
  comprador Usuario  @relation(fields: [compradorId], references: [id])

  @@index([vehiculoId])
  @@map("citas")
}

model Reporte {
  id         Int           @id @default(autoincrement())
  vehiculoId Int           @map("vehiculo_id")
  usuarioId  Int?          @map("usuario_id")
  motivo     String
  detalle    String?
  estado     EstadoReporte @default(abierto)
  creadoEn   DateTime      @default(now()) @map("creado_en")

  vehiculo Vehiculo @relation(fields: [vehiculoId], references: [id])
  usuario  Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([estado])
  @@map("reportes")
}

// ────────────────────── Financiamiento ──────────────────────

model EntidadFinanciera {
  id      Int     @id @default(autoincrement())
  nombre  String  @unique
  logoUrl String? @map("logo_url")
  activo  Boolean @default(true)

  planes PlanFinanciamiento[]

  @@map("entidades_financieras")
}

model PlanFinanciamiento {
  id             Int     @id @default(autoincrement())
  entidadId      Int     @map("entidad_id")
  nombre         String
  tasaAnual      Decimal @map("tasa_anual") @db.Decimal(5, 2)
  plazoMin       Int     @map("plazo_min")
  plazoMax       Int     @map("plazo_max")
  engancheMinPct Decimal @map("enganche_min_pct") @db.Decimal(5, 2)
  requisitos     Json?
  aplicaA        AplicaA @default(todos) @map("aplica_a")
  activo         Boolean @default(true)

  entidad     EntidadFinanciera  @relation(fields: [entidadId], references: [id])
  solicitudes SolicitudCredito[]

  @@map("planes_financiamiento")
}

model SolicitudCredito {
  id            Int                    @id @default(autoincrement())
  vehiculoId    Int                    @map("vehiculo_id")
  usuarioId     Int                    @map("usuario_id")
  planId        Int                    @map("plan_id")
  monto         Decimal                @db.Decimal(12, 2)
  enganche      Decimal                @db.Decimal(12, 2)
  plazo         Int
  cuotaEstimada Decimal                @map("cuota_estimada") @db.Decimal(12, 2)
  estado        EstadoSolicitudCredito @default(enviada)
  creadoEn      DateTime               @default(now()) @map("creado_en")

  vehiculo Vehiculo           @relation(fields: [vehiculoId], references: [id])
  usuario  Usuario            @relation(fields: [usuarioId], references: [id])
  plan     PlanFinanciamiento @relation(fields: [planId], references: [id])

  @@index([usuarioId])
  @@map("solicitudes_credito")
}

// ─────────────────────── Monetización ───────────────────────

model Plan {
  id                  Int     @id @default(autoincrement())
  nombre              String  @unique
  precioMensual       Decimal @map("precio_mensual") @db.Decimal(10, 2)
  maxAnuncios         Int     @map("max_anuncios")
  maxFotos            Int     @map("max_fotos")
  destacadosIncluidos Int     @default(0) @map("destacados_incluidos")

  suscripciones  Suscripcion[]
  concesionarios Concesionario[]

  @@map("planes")
}

model Suscripcion {
  id        Int               @id @default(autoincrement())
  usuarioId Int               @map("usuario_id")
  planId    Int               @map("plan_id")
  inicio    DateTime
  fin       DateTime
  estado    EstadoSuscripcion @default(activa)

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])

  @@index([usuarioId])
  @@map("suscripciones")
}

model Pago {
  id         Int          @id @default(autoincrement())
  usuarioId  Int          @map("usuario_id")
  concepto   ConceptoPago
  monto      Decimal      @db.Decimal(12, 2)
  moneda     Moneda       @default(GTQ)
  referencia String?
  estado     EstadoPago   @default(pendiente)
  creadoEn   DateTime     @default(now()) @map("creado_en")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@map("pagos")
}

// ───────────────── Multi-moneda: tipo de cambio ─────────────────
// Decisión de producto (2026-07-10): GTQ/USD con conversión. La tasa vigente
// es la de vigente_desde más reciente; el histórico permite auditar con qué
// tasa se normalizó cada precio.

model TipoCambio {
  id           Int      @id @default(autoincrement())
  // Quetzales por 1 USD
  tasaUsdGtq   Decimal  @map("tasa_usd_gtq") @db.Decimal(10, 5)
  vigenteDesde DateTime @map("vigente_desde")
  creadoEn     DateTime @default(now()) @map("creado_en")

  @@index([vigenteDesde(sort: Desc)])
  @@map("tipos_cambio")
}

// ─────────────────────── Auditoría ──────────────────────────
// Toda transición de estado y acción de admin se registra aquí.

model Auditoria {
  id            Int      @id @default(autoincrement())
  usuarioId     Int?     @map("usuario_id")
  accion        String
  entidad       String
  entidadId     Int      @map("entidad_id")
  datosAntes    Json?    @map("datos_antes")
  datosDespues  Json?    @map("datos_despues")
  ip            String?
  creadoEn      DateTime @default(now()) @map("creado_en")

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([entidad, entidadId])
  @@index([usuarioId])
  @@map("auditoria")
}
